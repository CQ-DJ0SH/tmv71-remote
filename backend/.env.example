# Copy to .env and adjust. All variables are optional (defaults shown).

# --- Serial link to the radio ---
TMV71_SERIAL_PORT=/dev/ttyUSB0
TMV71_SERIAL_BAUD=57600
TMV71_SERIAL_TIMEOUT=1.0

# --- HTTP server (LAN only) ---
TMV71_HOST=0.0.0.0
TMV71_PORT=8000
TMV71_POLL_INTERVAL=0.8

# --- Audio (direct WebRTC/Opus browser <-> radio via aiortc) ---
TMV71_AUDIO_ENABLED=true
TMV71_AUDIO_DEVICE=NAD
TMV71_RX_GAIN=1.0
TMV71_TX_GAIN=1.0

# --- GPIO power switch (relay on the radio's 12 V line) ---
# BCM pin; leave unset to disable. Settable from the web UI (Settings).
#TMV71_GPIO_POWER_PIN=17
#TMV71_GPIO_ACTIVE_HIGH=true
